// ═══════════════════════════════════════════════════════════════
// SECTION 3: AES-GCM Roundtrip Tests
// ═══════════════════════════════════════════════════════════════

@test
public func tls_aes128_gcm_encrypt_decrypt_roundtrip(env : &mut TestEnv) {
    var key : [16]u8 = [0xFE, 0xFF, 0xE9, 0x92, 0x86, 0x65, 0x73, 0x1C, 0x6D, 0x6A, 0x8F, 0x94, 0x67, 0x30, 0x83, 0x08]
    var iv : [12]u8 = [0xCA, 0xFE, 0xBA, 0xBE, 0xFA, 0xCE, 0xDB, 0xAD, 0xDE, 0xCA, 0xF8, 0x88]
    var plaintext : [16]u8 = [0xD9, 0x31, 0x32, 0x25, 0xF8, 0x84, 0x06, 0xE5, 0xA5, 0x59, 0x09, 0xC5, 0xAF, 0xF2, 0x69, 0x04]
    var gcm_ctx : tls::GCMContext
    var ret = tls::gcm_init(&raw mut gcm_ctx, &raw key[0], 16)
    if(ret < 0) { env.error("gcm_init failed"); return }

    // Encrypt
    var ciphertext : [16]u8
    var tag : [16]u8
    ret = tls::gcm_crypt_and_tag(&raw mut gcm_ctx, &raw iv[0], 12,
                                  null, 0,
                                  &raw plaintext[0], 16,
                                  &raw mut ciphertext[0], &raw mut tag[0])
    if(ret < 0) { env.error("gcm_crypt_and_tag failed"); return }

    // Tag must not be all zeros
    if(!bytes_not_zero(&raw tag[0], 16)) {
        env.error("GCM tag should not be all zeros")
    }

    // Ciphertext must differ from plaintext
    if(tls_bytes_equal(&raw ciphertext[0], &raw plaintext[0], 16)) {
        env.error("GCM ciphertext should differ from plaintext")
    }

    // Decrypt and verify roundtrip
    var decrypted : [16]u8
    var gcm_ctx2 : tls::GCMContext
    tls::gcm_init(&raw mut gcm_ctx2, &raw key[0], 16)
    ret = tls::gcm_auth_decrypt(&raw mut gcm_ctx2, &raw iv[0], 12,
                                 null, 0,
                                 &raw ciphertext[0], 16,
                                 &raw tag[0], 16,
                                 &raw mut decrypted[0])
    if(ret < 0) { env.error("gcm_auth_decrypt failed"); return }
    if(!tls_bytes_equal(&raw decrypted[0], &raw plaintext[0], 16)) {
        env.error("AES-128-GCM decrypt did not recover plaintext")
    }
}

@test
public func tls_aes128_gcm_aad_roundtrip(env : &mut TestEnv) {
    var key : [16]u8 = [0xFE, 0xFF, 0xE9, 0x92, 0x86, 0x65, 0x73, 0x1C, 0x6D, 0x6A, 0x8F, 0x94, 0x67, 0x30, 0x83, 0x08]
    var iv : [12]u8 = [0xCA, 0xFE, 0xBA, 0xBE, 0xFA, 0xCE, 0xDB, 0xAD, 0xDE, 0xCA, 0xF8, 0x88]
    var plaintext : [16]u8 = [0xD9, 0x31, 0x32, 0x25, 0xF8, 0x84, 0x06, 0xE5, 0xA5, 0x59, 0x09, 0xC5, 0xAF, 0xF2, 0x69, 0x04]
    var aad : [20]u8 = [0xFE, 0xED, 0xFA, 0xCE, 0xDE, 0xAD, 0xBE, 0xEF, 0xFE, 0xED, 0xFA, 0xCE, 0xDE, 0xAD, 0xBE, 0xEF, 0xAB, 0xAD, 0xDA, 0xD2]
    var gcm_ctx : tls::GCMContext
    tls::gcm_init(&raw mut gcm_ctx, &raw key[0], 16)

    var ciphertext : [16]u8
    var tag : [16]u8
    var ret = tls::gcm_crypt_and_tag(&raw mut gcm_ctx, &raw iv[0], 12,
                                      &raw aad[0], 20,
                                      &raw plaintext[0], 16,
                                      &raw mut ciphertext[0], &raw mut tag[0])
    if(ret < 0) { env.error("gcm_crypt_and_tag with AAD failed"); return }

    // Decrypt with same AAD should succeed
    var decrypted : [16]u8
    var gcm_ctx2 : tls::GCMContext
    tls::gcm_init(&raw mut gcm_ctx2, &raw key[0], 16)
    ret = tls::gcm_auth_decrypt(&raw mut gcm_ctx2, &raw iv[0], 12,
                                 &raw aad[0], 20,
                                 &raw ciphertext[0], 16,
                                 &raw tag[0], 16,
                                 &raw mut decrypted[0])
    if(ret < 0) { env.error("gcm_auth_decrypt with AAD failed"); return }
    if(!tls_bytes_equal(&raw decrypted[0], &raw plaintext[0], 16)) {
        env.error("AES-128-GCM AAD decrypt did not recover plaintext")
    }
}

@test
public func tls_aes128_gcm_tampered_tag_fails(env : &mut TestEnv) {
    var key : [16]u8 = [0xFE, 0xFF, 0xE9, 0x92, 0x86, 0x65, 0x73, 0x1C, 0x6D, 0x6A, 0x8F, 0x94, 0x67, 0x30, 0x83, 0x08]
    var iv : [12]u8 = [0xCA, 0xFE, 0xBA, 0xBE, 0xFA, 0xCE, 0xDB, 0xAD, 0xDE, 0xCA, 0xF8, 0x88]
    var plaintext : [16]u8 = [0xD9, 0x31, 0x32, 0x25, 0xF8, 0x84, 0x06, 0xE5, 0xA5, 0x59, 0x09, 0xC5, 0xAF, 0xF2, 0x69, 0x04]
    var gcm_ctx : tls::GCMContext
    tls::gcm_init(&raw mut gcm_ctx, &raw key[0], 16)

    var ciphertext : [16]u8
    var tag : [16]u8
    tls::gcm_crypt_and_tag(&raw mut gcm_ctx, &raw iv[0], 12,
                           null, 0,
                           &raw plaintext[0], 16,
                           &raw mut ciphertext[0], &raw mut tag[0])

    // Tamper with one tag byte
    tag[0] = tag[0] ^ 0xFF

    var decrypted : [16]u8
    var gcm_ctx2 : tls::GCMContext
    tls::gcm_init(&raw mut gcm_ctx2, &raw key[0], 16)
    var ret = tls::gcm_auth_decrypt(&raw mut gcm_ctx2, &raw iv[0], 12,
                                     null, 0,
                                     &raw ciphertext[0], 16,
                                     &raw tag[0], 16,
                                     &raw mut decrypted[0])
    if(ret == 0) {
        env.error("GCM should reject tampered tag")
    }
}

