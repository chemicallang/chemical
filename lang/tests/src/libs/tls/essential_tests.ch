@test
public func tls_prf_known_answer_key_expansion(env : &mut TestEnv) {
    var secret : [8]u8 = [0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08]
    var seed : [4]u8 = [0xDE, 0xAD, 0xBE, 0xEF]
    var expected_32 : [32]u8 = [0x03, 0xF7, 0x34, 0x7C, 0x95, 0x76, 0xDA, 0xF6, 0xD9, 0xD3, 0x76, 0xC7, 0xB8, 0x9B, 0xCB, 0x65, 0xF8, 0x58, 0x5D, 0xE7, 0x17, 0x44, 0xCC, 0xB2, 0x41, 0x72, 0x29, 0xF1, 0xE1, 0x7D, 0x63, 0x64]
    var expected_64 : [64]u8 = [0x03, 0xF7, 0x34, 0x7C, 0x95, 0x76, 0xDA, 0xF6, 0xD9, 0xD3, 0x76, 0xC7, 0xB8, 0x9B, 0xCB, 0x65, 0xF8, 0x58, 0x5D, 0xE7, 0x17, 0x44, 0xCC, 0xB2, 0x41, 0x72, 0x29, 0xF1, 0xE1, 0x7D, 0x63, 0x64, 0xBF, 0x96, 0xC9, 0x20, 0x35, 0xFE, 0x0F, 0x59, 0x96, 0xD8, 0x20, 0x14, 0x68, 0x56, 0x62, 0xC2, 0xE2, 0xA3, 0xEE, 0x47, 0xA6, 0x49, 0xF9, 0x8E, 0xE5, 0xA1, 0x4D, 0xF7, 0x12, 0x99, 0xDA, 0xD8]
    var output : [64]u8
    var label = "key expansion\0" as *char
    tls::tls12_prf(&raw secret[0], 8, label, 14, &raw seed[0], 4, &raw mut output[0], 64)
    if(!tls_bytes_equal(&raw output[0], &raw expected_32[0], 32)) {
        env.error("PRF key expansion first 32 bytes wrong")
    }
    if(!tls_bytes_equal(&raw output[32], &raw expected_64[32], 32)) {
        env.error("PRF key expansion bytes 32-63 wrong")
    }
}

