import lab
import std

public func build(ctx : *mut BuildContext, user_job : *mut LabJob) : *mut Module {

    const curr_file_path = lab::get_my_path();
    const cached = ctx.get_cached(user_job, curr_file_path);
    if(cached != null) {
        return cached;
    }

    var dependencies = std::vector<*mut Module>();

    if(user_job.getTarget().c) {
        const deps : []*mut Module = []
        var atomic_path = lab::rel_path_to("cruntime/atomic.c");
        const runtime_module = ctx.c_file_module(std::string_view(""), std::string_view("atomic_runtime"), atomic_path.to_view(), std::span<*mut Module>(deps, 0))
        dependencies.push(runtime_module)
    }

    var srcPath = lab::rel_path_to("src")
    const module = ctx.chemical_dir_module(std::string_view(""), std::string_view("atomic"), srcPath.to_view(), std::span<*mut Module>(dependencies));

    ctx.set_cached(user_job, curr_file_path, module)

    return module;

}