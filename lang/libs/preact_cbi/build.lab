import lab
import std

import "@cstd/build.lab" as cstdMod
import "@std/build.lab" as stdMod
import "@html_comp/build.lab" as htmlCompMod
import "@compiler/build.lab" as compilerMod
import "@preact_parser/build.lab" as preactParserMod
import "@preact_ide/build.lab" as preactIdeMod

using namespace std;

public func build(ctx : *mut BuildContext, user_job : *mut LabJob) : *mut Module {

    const curr_file_path = lab::get_my_path();
    const previous_module = ctx.get_cached(user_job, curr_file_path);
    if(previous_module != null) return previous_module;
    const empty_module = ctx.empty_module(std::string_view(""), std::string_view("preact_cbi"));
    ctx.set_cached(user_job, curr_file_path, empty_module)

    const cbi_name = std::string_view("preact");
    if(ctx.contains_cbi(cbi_name)) {
        return empty_module;
    }
    ctx.set_contains_cbi(cbi_name)

    // creating a marker annotation named 'component'
    const controller = ctx.getAnnotationController()
    controller.createMarkerAnnotation(std::string_view("component"))

    // preact cbi
    var cbi = ctx.build_cbi(cbi_name)
    const job = cbi;

    // makes sure this job is done before the user_job
    ctx.put_job_before(job, user_job)

    var std_module = stdMod.build(ctx, job);
    if(std_module == null) {
        return null
    }

    // the cstd module
    var cstd_module = cstdMod.build(ctx, job);
    if(cstd_module == null) {
        return null
    }

    // the html component module
    var html_comp_module = htmlCompMod.build(ctx, job)
    if(html_comp_module == null) {
        return null
    }

    // the std module
    var compiler_module = compilerMod.build(ctx, job);
    if(compiler_module == null) {
        return null
    }

    // the preact parser module
    var preact_parser = preactParserMod.build(ctx, job)
    if(preact_parser == null) {
        return null
    }

    // only compile html ide module in lsp
    var preactIde : *mut Module
    comptime if(def.lsp) {
        preactIde = preactIdeMod.build(ctx, job)
        if(preactIde == null) {
            return null;
        }
    } else {
        preactIde = preact_parser
    }

    const dependencies = [ cstd_module, std_module, html_comp_module, compiler_module, preact_parser, preactIde ]
    const module = ctx.chemical_dir_module(std::string_view(""), std::string_view("preact_cbi"), lab::rel_path_to("src").to_view(), dependencies);

    ctx.add_module(cbi, module)

    ctx.index_cbi_fn(cbi, std::string_view("preact"), std::string_view("preact_initializeLexer"), CBIFunctionType.InitializeLexer);
    ctx.index_cbi_fn(cbi, std::string_view("preact"), std::string_view("preact_parseMacroNode"), CBIFunctionType.ParseMacroTopLevelNode);
    ctx.index_cbi_fn(cbi, std::string_view("preact"), std::string_view("preact_symResDeclareNode"), CBIFunctionType.SymResDeclareTopLevelNode);
    ctx.index_cbi_fn(cbi, std::string_view("preact"), std::string_view("preact_symResSigNode"), CBIFunctionType.SymResLinkSignatureNode);
    ctx.index_cbi_fn(cbi, std::string_view("preact"), std::string_view("preact_symResNode"), CBIFunctionType.SymResNode);
    ctx.index_cbi_fn(cbi, std::string_view("preact"), std::string_view("preact_replacementNodeDeclare"), CBIFunctionType.ReplacementNodeDeclare);
    ctx.index_cbi_fn(cbi, std::string_view("preact"), std::string_view("preact_replacementNode"), CBIFunctionType.ReplacementNode);

    comptime if(def.lsp) {
        // this will let the lsp know that methods are present
        ctx.index_def_cbi_fn(cbi, std::string_view("preact_semanticTokensPut"), CBIFunctionType.SemanticTokensPut);
        ctx.index_def_cbi_fn(cbi, std::string_view("preact_foldingRangesPut"), CBIFunctionType.FoldingRangesPut);
    }

    return empty_module;

}