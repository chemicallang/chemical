import lab
import std

import "@cstd/build.lab" as cstdMod
import "@std/build.lab" as stdMod
import "@html_comp/build.lab" as htmlCompMod
import "@compiler/build.lab" as compilerMod
import "@solid_parser/build.lab" as solidParserMod
import "@solid_ide/build.lab" as solidIdeMod

using namespace std;

public func build(ctx : *mut BuildContext, user_job : *mut LabJob) : *mut Module {

    const curr_file_path = lab::get_my_path();
    const previous_module = ctx.get_cached(user_job, curr_file_path);
    if(previous_module != null) return previous_module;
    const empty_module = ctx.empty_module(std::string_view(""), std::string_view("solid_cbi"));
    ctx.set_cached(user_job, curr_file_path, empty_module)

    const cbi_name = std::string_view("solid");
    if(ctx.contains_cbi(cbi_name)) {
        return empty_module;
    }
    ctx.set_contains_cbi(cbi_name)

    // creating a marker annotation named 'component'
    const controller = ctx.getAnnotationController()
    controller.createMarkerAnnotation(std::string_view("component"))

    // solid cbi
    var cbi = ctx.build_cbi(cbi_name)
    const job = cbi;

    // makes sure this job is done before the user_job
    ctx.put_job_before(job, user_job)

    var std_module = stdMod.build(ctx, job);
    if(std_module == null) {
        return null
    }

    // the cstd module
    var cstd_module = cstdMod.build(ctx, job);
    if(cstd_module == null) {
        return null
    }

    // the html component module
    var html_comp_module = htmlCompMod.build(ctx, job)
    if(html_comp_module == null) {
        return null
    }

    // the std module
    var compiler_module = compilerMod.build(ctx, job);
    if(compiler_module == null) {
        return null
    }

    // the solid parser module
    var solid_parser = solidParserMod.build(ctx, job)
    if(solid_parser == null) {
        return null
    }

    // only compile html ide module in lsp
    var solidIde : *mut Module
    comptime if(def.lsp) {
        solidIde = solidIdeMod.build(ctx, job)
        if(solidIde == null) {
            return null;
        }
    } else {
        solidIde = solid_parser
    }

    const dependencies = [ cstd_module, std_module, html_comp_module, compiler_module, solid_parser, solidIde ]
    const module = ctx.chemical_dir_module(std::string_view(""), std::string_view("solid_cbi"), lab::rel_path_to("src").to_view(), dependencies);

    ctx.add_module(cbi, module)

    ctx.index_cbi_fn(cbi, std::string_view("solid"), std::string_view("solid_initializeLexer"), CBIFunctionType.InitializeLexer);
    ctx.index_cbi_fn(cbi, std::string_view("solid"), std::string_view("solid_parseMacroNode"), CBIFunctionType.ParseMacroTopLevelNode);
    ctx.index_cbi_fn(cbi, std::string_view("solid"), std::string_view("solid_symResDeclareNode"), CBIFunctionType.SymResDeclareTopLevelNode);
    ctx.index_cbi_fn(cbi, std::string_view("solid"), std::string_view("solid_symResSigNode"), CBIFunctionType.SymResLinkSignatureNode);
    ctx.index_cbi_fn(cbi, std::string_view("solid"), std::string_view("solid_symResNode"), CBIFunctionType.SymResNode);
    ctx.index_cbi_fn(cbi, std::string_view("solid"), std::string_view("solid_replacementNodeDeclare"), CBIFunctionType.ReplacementNodeDeclare);
    ctx.index_cbi_fn(cbi, std::string_view("solid"), std::string_view("solid_replacementNode"), CBIFunctionType.ReplacementNode);

    comptime if(def.lsp) {
        // this will let the lsp know that methods are present
        ctx.index_def_cbi_fn(cbi, std::string_view("solid_semanticTokensPut"), CBIFunctionType.SemanticTokensPut);
        ctx.index_def_cbi_fn(cbi, std::string_view("solid_foldingRangesPut"), CBIFunctionType.FoldingRangesPut);
    }

    return empty_module;

}